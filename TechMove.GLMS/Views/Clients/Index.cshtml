@model IEnumerable<TechMove.GLMS.Models.Client>

@{
    ViewData["Title"] = "Clients";
}

<h2>Clients</h2>

<div class="mb-3">
    <a asp-action="Create" class="btn btn-primary">New Client</a>
</div>

@if (!Model.Any())
{
    <p class="text-muted">No clients found.</p>
}
else
{
    <div class="table-responsive">
    <table class="table table-striped">
        <thead>
            <tr>
                <th>ID</th>
                <th>Name</th>
                <th>Region</th>
                <th>Contact</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var client in Model)
            {
                <tr>
                    <td>@client.Id</td>
                    <td>@client.Name</td>
                    <td>@(client.Region ?? "—")</td>
                    <td>@(client.ContactDetails ?? "—")</td>
                    <td>
                        <a asp-action="Details" asp-route-id="@client.Id" class="btn btn-sm btn-outline-primary">Details</a>
                        <a asp-action="Edit" asp-route-id="@client.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                        <a asp-action="Delete" asp-route-id="@client.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    </div>
}
