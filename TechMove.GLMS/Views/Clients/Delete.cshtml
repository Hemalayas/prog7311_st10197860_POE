@model TechMove.GLMS.Models.Client

@{
    ViewData["Title"] = $"Delete Client: {Model.Name}";
}

<h2>Delete Client</h2>

<div class="alert alert-danger" role="alert">
    Are you sure you want to delete this client? All associated contracts and service requests will also be deleted.
</div>

<div class="card mb-4" style="max-width: 480px;">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-4">Name</dt>
            <dd class="col-sm-8">@Model.Name</dd>

            <dt class="col-sm-4">Region</dt>
            <dd class="col-sm-8">@(Model.Region ?? "—")</dd>

            <dt class="col-sm-4">Contact</dt>
            <dd class="col-sm-8">@(Model.ContactDetails ?? "—")</dd>
        </dl>
    </div>
</div>

<form asp-action="Delete" asp-route-id="@Model.Id" method="post">
    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Cancel</a>
    </div>
</form>
