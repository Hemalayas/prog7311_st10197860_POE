@model TechMove.GLMS.Models.Contract

@{
    ViewData["Title"] = $"Delete Contract #{Model.Id}";
}

<h2>Delete Contract #@Model.Id</h2>

<div class="alert alert-danger" role="alert">
    Are you sure you want to delete this contract? This action cannot be undone.
</div>

<div class="card mb-4" style="max-width: 480px;">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-4">Client</dt>
            <dd class="col-sm-8">@Model.Client?.Name</dd>

            <dt class="col-sm-4">Start Date</dt>
            <dd class="col-sm-8">@Model.StartDate.ToString("yyyy-MM-dd")</dd>

            <dt class="col-sm-4">End Date</dt>
            <dd class="col-sm-8">@Model.EndDate.ToString("yyyy-MM-dd")</dd>

            <dt class="col-sm-4">Status</dt>
            <dd class="col-sm-8">
                <span class="badge @(Model.Status == TechMove.GLMS.Models.ContractStatus.Active ? "bg-success" :
                                      Model.Status == TechMove.GLMS.Models.ContractStatus.Expired ? "bg-danger" :
                                      Model.Status == TechMove.GLMS.Models.ContractStatus.OnHold ? "bg-secondary" :
                                      "bg-warning text-dark")">
                    @Model.Status
                </span>
            </dd>
        </dl>
    </div>
</div>

<form asp-action="Delete" asp-route-id="@Model.Id" method="post">
    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Cancel</a>
    </div>
</form>
