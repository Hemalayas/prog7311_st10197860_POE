@model TechMove.GLMS.Models.Contract

@{
    ViewData["Title"] = $"Contract #{Model.Id}";
}

<h2>Contract #@Model.Id</h2>

<div class="card mb-4">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Client</dt>
            <dd class="col-sm-9">@Model.Client?.Name</dd>

            <dt class="col-sm-3">Start Date</dt>
            <dd class="col-sm-9">@Model.StartDate.ToString("yyyy-MM-dd")</dd>

            <dt class="col-sm-3">End Date</dt>
            <dd class="col-sm-9">@Model.EndDate.ToString("yyyy-MM-dd")</dd>

            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">
                <span class="badge @(Model.Status == TechMove.GLMS.Models.ContractStatus.Active ? "bg-success" :
                                      Model.Status == TechMove.GLMS.Models.ContractStatus.Expired ? "bg-danger" :
                                      Model.Status == TechMove.GLMS.Models.ContractStatus.OnHold ? "bg-secondary" :
                                      "bg-warning text-dark")">
                    @Model.Status
                </span>
            </dd>

            <dt class="col-sm-3">Service Level</dt>
            <dd class="col-sm-9">@(Model.ServiceLevel ?? "—")</dd>

            <dt class="col-sm-3">Signed Agreement</dt>
            <dd class="col-sm-9">
                @if (!string.IsNullOrEmpty(Model.SignedAgreementPath))
                {
                    <a href="@Model.SignedAgreementPath" target="_blank" class="btn btn-sm btn-outline-primary">
                        Download PDF
                    </a>
                }
                else
                {
                    <span class="text-muted">No file uploaded</span>
                }
            </dd>
        </dl>
    </div>
</div>

<div id="sr-error" class="alert alert-danger d-none" role="alert">
    Cannot create a service request for a contract that is Expired or On Hold.
</div>

<div class="d-flex gap-2 mb-4">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Edit</a>
    <a id="new-sr-btn"
       href="@Url.Action("Create", "ServiceRequests", new { contractId = Model.Id })"
       class="btn btn-primary"
       data-status="@Model.Status">New Service Request</a>
</div>

@section Scripts {
    <script>
        (function () {
            var btn    = document.getElementById('new-sr-btn');
            var alert  = document.getElementById('sr-error');
            var blocked = ['Expired', 'OnHold'];

            btn.addEventListener('click', function (e) {
                if (blocked.indexOf(btn.dataset.status) !== -1) {
                    e.preventDefault();
                    alert.classList.remove('d-none');
                    btn.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
                } else {
                    alert.classList.add('d-none');
                }
            });
        })();
    </script>
}

<h4>Service Requests</h4>

@if (!Model.ServiceRequests.Any())
{
    <p class="text-muted">No service requests yet.</p>
}
else
{
    <div class="table-responsive">
    <table class="table table-sm table-bordered">
        <thead class="table-light">
            <tr>
                <th>ID</th>
                <th>Service Level</th>
                <th>Description</th>
                <th>Cost (USD)</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var sr in Model.ServiceRequests)
            {
                <tr>
                    <td>@sr.Id</td>
                    <td>@sr.ServiceLevel</td>
                    <td>@sr.Description</td>
                    <td>@sr.Cost.ToString("C")</td>
                    <td>
                        <span class="badge @(sr.Status == TechMove.GLMS.Models.ServiceRequestStatus.Approved ? "bg-success" :
                                              sr.Status == TechMove.GLMS.Models.ServiceRequestStatus.Rejected ? "bg-danger" :
                                              "bg-secondary")">
                            @sr.Status
                        </span>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    </div>
}

<a asp-action="Index" class="btn btn-outline-secondary mt-2">Back to List</a>
