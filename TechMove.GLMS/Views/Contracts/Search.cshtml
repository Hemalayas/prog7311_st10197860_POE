@model TechMove.GLMS.ViewModels.ContractSearchViewModel

@{
    ViewData["Title"] = "Search Contracts";
}

<h2>Search Contracts</h2>

<form asp-action="Search" method="get" class="mb-4">
    <div class="row g-3 align-items-end">
        <div class="col-md-3">
            <label asp-for="StartDate" class="form-label"></label>
            <input asp-for="StartDate" class="form-control" type="date" />
            <span asp-validation-for="StartDate" class="text-danger small"></span>
        </div>
        <div class="col-md-3">
            <label asp-for="EndDate" class="form-label"></label>
            <input asp-for="EndDate" class="form-control" type="date" />
            <span asp-validation-for="EndDate" class="text-danger small"></span>
        </div>
        <div class="col-md-3">
            <label asp-for="Status" class="form-label"></label>
            <select asp-for="Status" class="form-select">
                <option value="">— Any —</option>
                @foreach (var s in Enum.GetNames(typeof(TechMove.GLMS.Models.ContractStatus)))
                {
                    <option value="@s">@s</option>
                }
            </select>
        </div>
        <div class="col-md-3">
            <button type="submit" class="btn btn-primary w-100">Search</button>
        </div>
    </div>
</form>

@if (Model.Searched)
{
    @if (!Model.Results.Any())
    {
        <p class="text-muted">No contracts matched your criteria.</p>
    }
    else
    {
        <p class="text-muted">@Model.Results.Count() result(s) found.</p>
        <div class="table-responsive">
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Client</th>
                    <th>Start Date</th>
                    <th>End Date</th>
                    <th>Status</th>
                    <th>Service Level</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var contract in Model.Results)
                {
                    <tr>
                        <td>@contract.Id</td>
                        <td>@contract.Client?.Name</td>
                        <td>@contract.StartDate.ToString("yyyy-MM-dd")</td>
                        <td>@contract.EndDate.ToString("yyyy-MM-dd")</td>
                        <td>
                            <span class="badge @(contract.Status == TechMove.GLMS.Models.ContractStatus.Active ? "bg-success" :
                                                  contract.Status == TechMove.GLMS.Models.ContractStatus.Expired ? "bg-danger" :
                                                  contract.Status == TechMove.GLMS.Models.ContractStatus.OnHold ? "bg-secondary" :
                                                  "bg-warning text-dark")">
                                @contract.Status
                            </span>
                        </td>
                        <td>@contract.ServiceLevel</td>
                        <td>
                            <a asp-action="Details" asp-route-id="@contract.Id" class="btn btn-sm btn-outline-primary">Details</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        </div>
    }
}

<a asp-action="Index" class="btn btn-outline-secondary mt-2">Back to List</a>
